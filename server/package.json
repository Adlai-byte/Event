{
  "name": "event-server",
  "version": "1.0.0",
  "description": "Event App Backend Server",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "test": "jest --runInBand --passWithNoTests",
    "test:watch": "jest --runInBand --watch",
    "test:coverage": "jest --runInBand --coverage",
    "test:db": "node test-db-connection.js",
    "migrate:up": "npx knex migrate:latest --knexfile knexfile.js",
    "migrate:down": "npx knex migrate:rollback --knexfile knexfile.js",
    "migrate:status": "npx knex migrate:status --knexfile knexfile.js",
    "seed": "npx knex seed:run --knexfile knexfile.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.1.0",
    "knex": "^3.1.0",
    "mysql2": "^3.11.0",
    "pdfkit": "^0.17.2",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true,
  "devDependencies": {
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  }
}
