# =============================================================================
# E-Vent Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env files with real credentials to version control.
# =============================================================================

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=event
DB_ROOT_PASSWORD=your_db_root_password_here
DB_PORT=3306
DB_POOL_SIZE=50

# Server Configuration
PORT=3001
NODE_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# Payment Gateway - PayMongo
# Get keys from https://dashboard.paymongo.com
PAYMONGO_SECRET_KEY=sk_test_your_key_here
PAYMONGO_PUBLIC_KEY=pk_test_your_key_here
PAYMONGO_MODE=test

# Payment Gateway - Dragonpay (optional)
# DRAGONPAY_MERCHANT_ID=your_merchant_id
# DRAGONPAY_PASSWORD=your_password

# Firebase Admin SDK
# Path to your Firebase service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# JWT Secret (if using JWT)
# JWT_SECRET=your_jwt_secret_here

# Email Configuration (for transactional emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Logging
LOG_LEVEL=debug

# Redis (for caching & rate limiting in production)
# REDIS_URL=redis://localhost:6379
