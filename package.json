{
  "name": "event",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "cross-env EXPO_PUBLIC_API_BASE_URL=http://192.168.254.104:3001 expo start --clear",
    "start:fast": "cross-env EXPO_PUBLIC_API_BASE_URL=http://192.168.254.104:3001 expo start",
    "start:localhost": "expo start --clear",
    "android": "cross-env EXPO_PUBLIC_API_BASE_URL=http://192.168.254.104:3001 expo start --android --clear",
    "ios": "cross-env EXPO_PUBLIC_API_BASE_URL=http://192.168.254.104:3001 expo start --ios --clear",
    "web": "expo start --web --clear",
    "test:db": "node server/test-db-connection.js",
    "server": "node server/index.js",
    "server:check": "node check-server.js",
    "server:test-emulator": "node test-emulator-connection.js",
    "server:restart": "powershell -ExecutionPolicy Bypass -File ./restart-server.ps1",
    "type-check": "tsc --noEmit",
    "clean": "npx expo start --clear && Remove-Item -Recurse -Force .expo -ErrorAction SilentlyContinue",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "build:ios:production": "eas build --platform ios --profile production",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "expo": "~54.0.25",
    "expo-auth-session": "^7.0.9",
    "expo-crypto": "^15.0.7",
    "expo-image-picker": "^17.0.8",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "^15.0.9",
    "express": "^4.21.2",
    "firebase": "^12.2.1",
    "mysql2": "^3.11.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
