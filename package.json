{
  "name": "event",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node scripts/start-expo-with-ip.js --clear",
    "start:fast": "node scripts/start-expo-with-ip.js",
    "start:localhost": "expo start --clear",
    "android": "node scripts/start-expo-with-ip.js --android --clear",
    "ios": "node scripts/start-expo-with-ip.js --ios --clear",
    "web": "node scripts/start-expo-with-ip.js --web --clear",
    "test:db": "node server/test-db-connection.js",
    "server": "node server/index.js",
    "server:check": "node check-server.js",
    "server:test-emulator": "node test-emulator-connection.js",
    "server:restart": "powershell -ExecutionPolicy Bypass -File ./restart-server.ps1",
    "type-check": "tsc --noEmit",
    "clean": "npx expo start --clear && Remove-Item -Recurse -Force .expo -ErrorAction SilentlyContinue"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "expo": "~54.0.27",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "^18.0.11",
    "expo-crypto": "~15.0.8",
    "expo-device": "^8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "^19.0.19",
    "expo-image-picker": "~17.0.9",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.14",
    "expo-server-sdk": "^4.0.0",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^4.21.2",
    "firebase": "^12.2.1",
    "mysql2": "^3.11.0",
    "pdfkit": "^0.17.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "cross-env": "^10.1.0",
    "eas-cli": "^16.28.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
