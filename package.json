{
  "name": "event",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node scripts/start-expo-with-ip.js --clear",
    "start:fast": "node scripts/start-expo-with-ip.js",
    "start:localhost": "expo start --clear",
    "android": "node scripts/start-expo-with-ip.js --android --clear",
    "ios": "node scripts/start-expo-with-ip.js --ios --clear",
    "web": "node scripts/start-expo-with-ip.js --web --clear",
    "server": "node server/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"mvc/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"mvc/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:server": "cd server && npm test",
    "clean": "npx expo start --clear",
    "build:android": "powershell -ExecutionPolicy Bypass -File ./build-android.ps1",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@tanstack/react-query": "^5.90.20",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "docx": "^9.6.0",
    "dotenv": "^16.4.5",
    "expo": "~54.0.27",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~15.0.1",
    "expo-constants": "^18.0.11",
    "expo-crypto": "~15.0.8",
    "expo-device": "^8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "^19.0.19",
    "expo-image-picker": "~17.0.9",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.14",
    "expo-router": "~6.0.23",
    "expo-server-sdk": "^4.0.0",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^4.21.2",
    "firebase": "^12.6.0",
    "mysql2": "^3.11.0",
    "nativewind": "^4.2.2",
    "pdfkit": "^0.17.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-loading-indicators": "^1.0.1",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.0",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "cross-env": "^10.1.0",
    "eas-cli": "^16.28.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.1"
  },
  "private": true
}
